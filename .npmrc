# pnpm 11+ settings for plureslm-openclaw
#
# 1) Don't run the implicit `pnpm install` dependency-status check before every
#    `pnpm run <script>`. That check exits non-zero purely because of the
#    ignored-build-scripts notice below, which would otherwise mask a clean
#    `tsc` build. Our build/check scripts call tsc directly and need no install.
verify-deps-before-run=false

# 2) Allow ONLY esbuild to run its postinstall (vitest needs the platform
#    binary). Everything else (genai/protobufjs/openclaw/tree-sitter) stays
#    sandboxed — we never execute their postinstalls.
only-built-dependencies[]=esbuild
